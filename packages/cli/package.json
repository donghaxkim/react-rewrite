{
  "name": "frameup",
  "version": "0.1.0",
  "description": "Visual overlay for React dev servers — select components, drag to reorder, and draw on a Figma-style canvas",
  "keywords": [
    "react",
    "devtools",
    "visual",
    "overlay",
    "figma",
    "component",
    "drag-and-drop",
    "jsx",
    "ast",
    "cli"
  ],
  "homepage": "https://github.com/donghaxkim/frameup",
  "repository": {
    "type": "git",
    "url": "https://github.com/donghaxkim/frameup.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Dongha Kim",
  "bin": {
    "frameup": "./bin/frameup.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc && cp ../overlay/dist/overlay.js dist/overlay.js && mkdir -p dist/fonts && cp src/fonts/*.woff2 dist/fonts/",
    "dev": "tsc --watch",
    "test": "vitest",
    "prepublishOnly": "pnpm run build && pnpm run test -- --run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "~0.80.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "dotenv": "^17.3.1",
    "http-proxy": "^1.18.1",
    "jscodeshift": "^17.1.0",
    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@frameup/shared": "workspace:*",
    "@types/http-proxy": "^1.17.15",
    "@types/jscodeshift": "^17.3.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
