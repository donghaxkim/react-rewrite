{
  "name": "react-rewrite-cli",
  "version": "0.1.1",
  "description": "Visual overlay for React dev servers — select components, drag to reorder, and draw on a Figma-style canvas",
  "keywords": [
    "react",
    "devtools",
    "visual",
    "overlay",
    "figma",
    "component",
    "drag-and-drop",
    "jsx",
    "ast",
    "cli"
  ],
  "homepage": "https://github.com/donghaxkim/react-rewrite",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donghaxkim/react-rewrite.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Dongha Kim",
  "bin": {
    "react-rewrite": "bin/react-rewrite.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc && cp ../overlay/dist/overlay.js dist/overlay.js && mkdir -p dist/fonts && cp src/fonts/*.woff2 dist/fonts/",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "pnpm run build && pnpm run test:run"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "esbuild": "^0.28.0",
    "http-proxy": "^1.18.1",
    "jscodeshift": "^17.1.0",
    "open": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@react-rewrite/shared": "workspace:*",
    "@types/http-proxy": "^1.17.15",
    "@types/jscodeshift": "^17.3.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
