{
  "name": "sketch-ui-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm build:overlay && pnpm build:cli",
    "build:overlay": "pnpm --filter @sketch-ui/overlay build",
    "build:cli": "pnpm --filter sketch-ui build",
    "dev": "pnpm build:overlay && pnpm --filter sketch-ui dev",
    "test": "pnpm --filter sketch-ui test"
  },
  "engines": {
    "node": ">=18"
  }
}
